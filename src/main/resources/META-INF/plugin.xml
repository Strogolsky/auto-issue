<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.strogolsky.autoissue</id>
    <name>auto-issue</name>
    <vendor>strogolsky</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.AutoIssueBundle</resource-bundle>

    <extensionPoints>
        <extensionPoint
            name="llmProviderFactory"
            interface="com.github.strogolsky.autoissue.core.agent.LlmProvider"
            dynamic="true"/>
        <extensionPoint
            name="issueStrategyFactory"
            interface="com.github.strogolsky.autoissue.core.agent.strategy.IssueStrategyFactory"
            dynamic="true"/>
        <extensionPoint
            name="contextComponentProvider"
            interface="com.github.strogolsky.autoissue.core.context.providers.ContextComponentProvider"
            dynamic="true"/>
        <extensionPoint
            name="promptRenderer"
            interface="com.github.strogolsky.autoissue.core.context.render.PromptRenderer"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">

        <postStartupActivity implementation="com.github.strogolsky.autoissue.plugin.startup.PluginStartupActivity" />


        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="com.github.strogolsky.autoissue.ui.action.TodoLineMarkerProvider"/>

        <notificationGroup id="AutoIssue Notifications" displayType="BALLOON"/>

        <applicationConfigurable parentId="tools"
                                 id="com.github.strogolsky.autoissue.Main"
                                 displayName="AutoIssue"
                                 instance="com.github.strogolsky.autoissue.ui.components.AutoIssueMainConfigurable"/>

        <applicationConfigurable parentId="com.github.strogolsky.autoissue.Main"
                                 id="com.github.strogolsky.autoissue.Jira"
                                 displayName="Jira Integration"
                                 instance="com.github.strogolsky.autoissue.ui.components.JiraSettingsConfigurable"/>

        <applicationConfigurable parentId="com.github.strogolsky.autoissue.Main"
                                 id="com.github.strogolsky.autoissue.LLM"
                                 displayName="LLM Agent"
                                 instance="com.github.strogolsky.autoissue.ui.components.LlmSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="com.github.strogolsky.autoissue">
        <llmProviderFactory
            implementation="com.github.strogolsky.autoissue.core.agent.GoogleLlmProvider"/>
        <issueStrategyFactory
            implementation="com.github.strogolsky.autoissue.core.agent.strategy.JiraDirectStrategyFactory"/>
        <issueStrategyFactory
            implementation="com.github.strogolsky.autoissue.core.agent.strategy.JiraReasoningStrategyFactory"/>
        <contextComponentProvider
            implementation="com.github.strogolsky.autoissue.core.context.providers.FileContextComponentProvider"/>
        <contextComponentProvider
            implementation="com.github.strogolsky.autoissue.core.context.providers.JiraMetadataProvider"/>
        <promptRenderer
            implementation="com.github.strogolsky.autoissue.core.context.render.PlainTextPromptRenderer"/>
        <promptRenderer
            implementation="com.github.strogolsky.autoissue.core.context.render.MarkdownPromptRenderer"/>
        <promptRenderer
            implementation="com.github.strogolsky.autoissue.core.context.render.XmlPromptRenderer"/>
    </extensions>
</idea-plugin>
