<plugin-config>

  <llm>
    <default-provider>GOOGLE</default-provider>
    <default-model>gemini-2.5-flash</default-model>
    <default-strategy>jira-reasoning-strategy</default-strategy>
    <temperature>0.0</temperature>
    <max-iterations>50</max-iterations>
    <system-prompt file="prompts/system-prompt.md"/>
    <examples file="prompts/examples.md"/>
  </llm>

  <rendering>
    <format>SIMPLE</format> <!-- MARKDOWN | XML -->
  </rendering>
  <dev>
    <!-- set enabled="false" to disable the mechanism entirely -->
    <local-properties enabled="true">local.properties</local-properties>
  </dev>

  <masking>
    <enabled>true</enabled>
  </masking>

</plugin-config>
